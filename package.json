{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset-orders": "tsx prisma/reset-orders.ts",
    "prestart": "prisma generate",
    "load:catalog": "k6 run load/catalog.js",
    "db:seed-admin": "tsx prisma/seed-admin.ts",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --tsconfig server/tsconfig.json server/src/main.ts",
    "start": "node dist/server/main.js",
    "test": "jest"
  },
